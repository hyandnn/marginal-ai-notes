{
  "manifest_version": 3,
  "name": "Agent Sidenote",
  "version": "1.5.0",
  "description": "在 AI 对话网页选中文字，用便签旁注追问并导出 Markdown 笔记。支持 ChatGPT、豆包。",
  "permissions": ["storage", "tabs", "downloads"],
  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://www.doubao.com/*",
    "https://doubao.com/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background/service_worker.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://www.doubao.com/*",
        "https://doubao.com/*"
      ],
      "js": [
        "shared/note_schema.js",
        "shared/export.js",
        "content/adapters/shared.js",
        "content/adapters/index.js",
        "content/adapters/chatgpt.js",
        "content/adapters/doubao.js",
        "content/marked.min.js",
        "content/storage.js",
        "content/api_client.js",
        "content/selection.js",
        "content/note_manager.js",
        "content/route_manager.js",
        "content/content.js"
      ],
      "css": ["content/content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "旁注追问设置"
  }
}
